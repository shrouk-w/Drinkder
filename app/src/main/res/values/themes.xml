<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Drinkder" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/apricot_500</item>
        <item name="colorPrimaryVariant">@color/rum_700</item>
        <item name="colorOnPrimary">@color/cream_100</item>
        <item name="colorSecondary">@color/mint_300</item>
        <item name="colorSecondaryVariant">@color/apricot_300</item>
        <item name="colorOnSecondary">@color/rum_900</item>
        <item name="colorSurface">@color/cream_100</item>
        <item name="colorOnSurface">@color/rum_900</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/rum_900</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Drinkder.Medium</item>
    </style>

    <style name="ShapeAppearance.Drinkder.Medium" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="ShapeAppearance.Drinkder.ImageTop" parent="">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
    </style>
</resources>
