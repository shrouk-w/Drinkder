<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="14dp"
    android:paddingTop="24dp"
    android:paddingEnd="14dp"
    tools:context=".ui.dashboard.DashboardFragment">

    <TextView
        android:id="@+id/saved_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title_dashboard"
        android:textColor="@color/cream_100"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/action_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/saved_title">

        <LinearLayout
            android:id="@+id/default_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clear_all_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/clear_all"
                android:minWidth="0dp"
                android:paddingHorizontal="14dp"
                android:textColor="@color/cream_100"
                app:backgroundTint="#1AFFFFFF"
                app:cornerRadius="18dp"
                app:strokeColor="#22FFFFFF"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selection_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/selection_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/cream_100"
                android:textSize="15sp"
                tools:text="2 selected" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancel_selection_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/cancel"
                android:minWidth="0dp"
                android:paddingHorizontal="14dp"
                android:textColor="@color/cream_100"
                app:backgroundTint="#1AFFFFFF"
                app:cornerRadius="18dp"
                app:strokeColor="#22FFFFFF"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/delete_selected_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/delete_selected"
                android:minWidth="0dp"
                android:paddingHorizontal="14dp"
                android:textColor="@color/rum_900"
                app:backgroundTint="@color/apricot_300"
                app:cornerRadius="18dp" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/empty_state"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/saved_empty_title"
        android:textColor="@color/cream_100"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/action_bar" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/favoritesRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/action_bar" />

</androidx.constraintlayout.widget.ConstraintLayout>
